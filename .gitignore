# ===========================================
# .gitignore - InkPage Project
# Vue.js + Vite + Express.js + TailwindCSS
# ===========================================

# ===========================================
# Node.js
# ===========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
yarn.lock
pnpm-debug.log*
lerna-debug.log*

# ===========================================
# Build Output (Vite)
# ===========================================
dist/
dist-ssr/
*.local

# ===========================================
# Environment Variables
# ===========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# ===========================================
# Logs
# ===========================================
logs/
*.log

# ===========================================
# Editor / IDE
# ===========================================
# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains IDEs (IntelliJ, WebStorm, PhpStorm)
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp

# Visual Studio
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ===========================================
# Operating System
# ===========================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ===========================================
# Testing & Coverage
# ===========================================
coverage/
.nyc_output/
*.lcov
test-automation/reports/*.json

# ===========================================
# Cache & Temporary Files
# ===========================================
.cache/
.temp/
.tmp/
*.tsbuildinfo
.eslintcache
.stylelintcache
*.pem

# ===========================================
# TypeScript
# ===========================================
*.tsbuildinfo

# ===========================================
# Build Artifacts
# ===========================================
*.tgz
*.crx
*.pem
*.zip

# ===========================================
# Documentation Generated
# ===========================================
docs/_build/
site/

# ===========================================
# Misc
# ===========================================
*.bak
*.backup
*.orig
*.pid
*.seed
*.pid.lock
.lock-wscript
.node_repl_history
*.pnp.cjs
*.pnp.js
.yarn-integrity
